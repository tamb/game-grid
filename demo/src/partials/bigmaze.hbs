                  <button id="regenerate-maze2" class="btn btn-primary">Regenerate Maze</button> -->
    </div>
    <div class='col-12 col-xl-5 order-1 order-xl-2'>
      <div class='demo-grid-wrap demo-grid-wrap--tall mx-auto'>
        <div id='maze'></div>
        {{> touchpad id="bigmaze-demo-dpad"}}
      </div>
    </div>
  </div>
</div>